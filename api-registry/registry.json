        { "id": "tri", "name": "EPA TRI", "docs": "https://www.epa.gov/toxics-release-inventory-tri-program" },
        { "id": "usgs_water", "name": "USGS Water Quality", "docs": "https://waterservices.usgs.gov/" }
      ]
    },
