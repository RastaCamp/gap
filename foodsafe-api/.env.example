PORT=3001
ADMIN_TOKEN=dev-token-change-me
DB_PATH=./data/foodsafe.db
DISABLED_SOURCES=

# Paid data API: when not false, /api/* data routes need an active Stripe subscription (or admin).
REQUIRE_PAID_API=true

# Monthly subscription USD (default 20). Used for Checkout if STRIPE_PRICE_ID is unset; exposed as GET /api/pricing.
MONTHLY_PRICE_USD=20

# Default admin (created/updated on API startup; use a strong secret — do not commit real passwords)
DEFAULT_ADMIN_EMAIL=rastacampllc@gmail.com
DEFAULT_ADMIN_PASSWORD=

# Set false to disable self-service client registration
# ALLOW_PUBLIC_REGISTER=false

# Optional: broadcast email to all client accounts (role=user)
# RESEND_API_KEY=
# RESEND_FROM=Your App <billing@yourdomain.com>

# Stripe (set STRIPE_PRICE_ID to use a Dashboard Price; otherwise Checkout uses MONTHLY_PRICE_USD)
# STRIPE_PRODUCT_NAME=FoodSafe API
# STRIPE_PRODUCT_DESCRIPTION=Monthly API access
# STRIPE_SECRET_KEY=
# STRIPE_PRICE_ID=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_SUCCESS_URL=http://localhost:5173/#/dashboard?billing=success
# STRIPE_CANCEL_URL=http://localhost:5173/#/pricing?billing=cancel
